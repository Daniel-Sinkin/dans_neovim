{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dans.local/neovim/knowledge/record.schema.json",
  "title": "Agent project-knowledge record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "id",
    "kind",
    "status",
    "title",
    "summary",
    "details",
    "scope",
    "provenance",
    "evidence",
    "relations",
    "retrieval",
    "last_verified"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "id": { "type": "string", "pattern": "^[A-Z]{3}-[0-9]{3}$" },
    "kind": {
      "enum": [
        "invariant",
        "decision",
        "behavior",
        "component",
        "incident",
        "question",
        "history"
      ]
    },
    "status": {
      "enum": [
        "accepted",
        "observed",
        "resolved",
        "open",
        "superseded",
        "retired"
      ]
    },
    "title": { "type": "string", "minLength": 1 },
    "summary": { "type": "string", "minLength": 1 },
    "details": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "rationale": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "alternatives": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "scope": { "type": "array", "items": { "type": "string", "minLength": 1 }, "minItems": 1 },
    "tags": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "provenance": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["kind", "reference", "note"],
        "properties": {
          "kind": { "enum": ["owner", "code", "test", "git", "analysis"] },
          "reference": { "type": "string", "minLength": 1 },
          "note": { "type": "string", "minLength": 1 }
        }
      }
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["kind", "reference", "claim"],
        "properties": {
          "kind": { "enum": ["test", "source", "commit", "owner"] },
          "reference": { "type": "string", "minLength": 1 },
          "claim": { "type": "string", "minLength": 1 }
        }
      }
    },
    "relations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["type", "target"],
        "properties": {
          "type": {
            "enum": [
              "constrains",
              "constrained_by",
              "implements",
              "implemented_by",
              "tests",
              "tested_by",
              "motivates",
              "motivated_by",
              "caused",
              "caused_by",
              "resolves",
              "resolved_by",
              "supersedes",
              "superseded_by",
              "relates_to",
              "opens"
            ]
          },
          "target": { "type": "string", "pattern": "^[A-Z]{3}-[0-9]{3}$" }
        }
      }
    },
    "retrieval": {
      "type": "object",
      "additionalProperties": false,
      "required": ["aliases", "questions"],
      "properties": {
        "aliases": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "questions": { "type": "array", "items": { "type": "string", "minLength": 1 } }
      }
    },
    "last_verified": {
      "type": "object",
      "additionalProperties": false,
      "required": ["date", "revision", "method"],
      "properties": {
        "date": { "type": "string", "format": "date" },
        "revision": { "type": "string", "minLength": 1 },
        "method": { "type": "string", "minLength": 1 }
      }
    }
  }
}
